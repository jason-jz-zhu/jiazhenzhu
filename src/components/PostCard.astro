---
interface Props {
  title: string;
  description: string;
  date: Date;
  slug: string;
  tags?: string[];
}

const { title, description, date, slug, tags = [] } = Astro.props;

const tagLabels: Record<string, string> = {
  'ai': 'AI',
  'ai-productivity': 'AI Productivity',
  'ai-agents': 'AI Agents',
  'ai-strategy': 'AI Strategy',
  'startup': 'Startup',
  'career': 'Career',
  'claude-code': 'Claude Code',
  'data-ml-infra': 'Data/ML Infra',
  'developer-tools': 'Developer Tools',
  'yc': 'YC',
  'personal-ip': 'Personal IP',
};
const formatTag = (tag: string) => tagLabels[tag] || tag.split('-').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
  timeZone: 'UTC',
});
---
<article class="group">
  <a href={`/blog/${slug}`} class="block py-5 -mx-3 px-3 rounded-lg transition-colors hover:bg-[var(--bg-secondary)]">
    <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1 mb-1.5">
      <h3 class="font-serif text-xl font-semibold tracking-tight group-hover:text-[var(--accent)] transition-colors">
        {title}
      </h3>
      <time
        datetime={date.toISOString()}
        class="text-sm shrink-0"
        style="color: var(--text-secondary);"
      >
        {formattedDate}
      </time>
    </div>
    <p class="text-sm leading-relaxed" style="color: var(--text-secondary);">
      {description}
    </p>
    {tags.length > 0 && (
      <div class="flex gap-2 mt-2">
        {tags.map((tag) => (
          <span
            class="text-xs px-2 py-0.5 rounded-full"
            style="background-color: var(--bg-secondary); color: var(--text-secondary);"
          >
            {formatTag(tag)}
          </span>
        ))}
      </div>
    )}
  </a>
</article>
