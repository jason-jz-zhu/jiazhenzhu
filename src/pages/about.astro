---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="About — Jiazhen Zhu" description="Learn more about Jiazhen Zhu.">
  <header class="mb-10">
    <h1 class="text-3xl sm:text-4xl font-bold tracking-tight mb-3">About</h1>
  </header>

  <div class="prose-custom">
    <p>
      Hi, I'm Jiazhen Zhu — a developer passionate about building thoughtful products on the web.
    </p>

    <p>
      I enjoy working across the full stack, with a particular interest in
      frontend engineering, data visualization, and developer tooling.
      I believe in writing clean, simple code and building things that are
      both useful and well-crafted.
    </p>

    <h2>What I Do</h2>
    <ul>
      <li>Build web applications with modern frameworks</li>
      <li>Create data visualizations and interactive experiences</li>
      <li>Write about technology and share what I learn</li>
    </ul>

    <h2>Tech I Work With</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 my-6 not-prose">
      {[
        'JavaScript / TypeScript',
        'React / Next.js',
        'Astro',
        'Node.js',
        'Python',
        'D3.js',
        'Tailwind CSS',
        'GraphQL',
        'Git',
      ].map((tech) => (
        <div
          class="text-sm px-3 py-2 rounded-lg text-center"
          style="background-color: var(--bg-secondary); color: var(--text-secondary);"
        >
          {tech}
        </div>
      ))}
    </div>

    <h2>Get in Touch</h2>
    <p>
      I'm always open to interesting conversations and collaborations.
      Feel free to reach out via <a href="mailto:hello@jiazhenzhu.com">email</a> or
      find me on <a href="https://github.com/jiazhenzhu" target="_blank" rel="noopener noreferrer">GitHub</a>.
    </p>
  </div>
</BaseLayout>
