---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Contact — Jiazhen Zhu" description="Get in touch with Jiazhen Zhu.">
  <header class="mb-10">
    <h1 class="text-3xl sm:text-4xl font-bold tracking-tight mb-3">Contact</h1>
    <p style="color: var(--text-secondary);">
      Want to chat about data, AI, or something you're working on? I'd love to hear from you.
    </p>
  </header>

  <div class="max-w-lg">
    <form action="https://formspree.io/f/xwvwyvlj" method="POST" class="space-y-4">
      <div>
        <label for="name" class="block text-sm font-medium mb-1.5">Name</label>
        <input
          type="text"
          id="name"
          name="name"
          required
          class="w-full px-4 py-2.5 rounded-lg border text-sm transition-colors focus:outline-none focus:ring-2"
          style="border-color: var(--border); background-color: var(--bg); color: var(--text); --tw-ring-color: var(--accent);"
        />
      </div>
      <div>
        <label for="email" class="block text-sm font-medium mb-1.5">Email</label>
        <input
          type="email"
          id="email"
          name="email"
          required
          class="w-full px-4 py-2.5 rounded-lg border text-sm transition-colors focus:outline-none focus:ring-2"
          style="border-color: var(--border); background-color: var(--bg); color: var(--text); --tw-ring-color: var(--accent);"
        />
      </div>
      <div>
        <label for="message" class="block text-sm font-medium mb-1.5">Message</label>
        <textarea
          id="message"
          name="message"
          rows="5"
          required
          class="w-full px-4 py-2.5 rounded-lg border text-sm transition-colors focus:outline-none focus:ring-2 resize-y"
          style="border-color: var(--border); background-color: var(--bg); color: var(--text); --tw-ring-color: var(--accent);"
        ></textarea>
      </div>
      <button
        type="submit"
        class="text-sm font-medium px-6 py-2.5 rounded-lg transition-opacity hover:opacity-90"
        style="background-color: var(--accent); color: white;"
      >
        Send
      </button>
    </form>

    <p class="text-sm mt-6" style="color: var(--text-secondary);">
      You can also reach me at
      <a href="mailto:hello@jiazhenzhu.com" class="underline underline-offset-2" style="color: var(--accent);">
        hello@jiazhenzhu.com
      </a>
    </p>
  </div>
</BaseLayout>
