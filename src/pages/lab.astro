---
import BaseLayout from '../layouts/BaseLayout.astro';

const projects = [
  {
    title: 'Orka',
    description: 'Treats a pipeline as a composite skill — the DAG is the skill, written in SKILL.md (a cross-vendor open format). Author skills in any AI chat, and Orka becomes the management, execution, and observability layer: visual canvas, scheduling, Mac-native outputs (Apple Notes, iCloud, webhooks) that cloud tools cannot reach.',
    tags: ['AI Agents', 'macOS', 'Tauri', 'Claude Code'],
    page: '/lab/orka',
    github: 'https://github.com/jason-jz-zhu/orka',
    status: 'WIP',
  },
  {
    title: 'JobAgent',
    description: 'AI agent that finds jobs, tailors your resume, and prepares a complete application package — in 3 minutes per app. Uses Claude Code + MCP servers for job scraping, JD analysis, and expert-guided resume rewriting.',
    tags: ['AI Agents', 'Career', 'Claude Code'],
    github: 'https://github.com/jason-jz-zhu/job-finding-and-resume-adjust',
    status: 'WIP',
  },
  {
    title: 'Harness Design Experiment',
    description: 'Tested 3 multi-agent harness architectures (Solo, Generator+Evaluator, Planner+Generator+Evaluator) on the same task to measure quality, time, and reliability differences. Found that a 3-agent harness with browser-based evaluation catches bugs that code review misses.',
    tags: ['AI Agents', 'Data/ML Infra', 'Harness Design', 'Experiment'],
    github: 'https://github.com/jason-jz-zhu/harness-design-experiment',
    blog: '/blog/harness-design',
    status: 'Completed',
  },
];
---
<BaseLayout title="Lab — Jiazhen Zhu" description="Experiments, open source projects, and ideas by Jiazhen Zhu.">
  <header class="mb-10">
    <h1 class="font-serif text-5xl sm:text-6xl font-bold tracking-tight mb-4">Lab</h1>
    <p style="color: var(--text-secondary);">
      Active experiments in AI systems, infrastructure, and tooling.
    </p>
  </header>

  <div class="space-y-5">
    {projects.map((project) => (
      <div
        class="p-6 rounded-xl border"
        style="border-color: var(--border);"
      >
        <div class="flex items-start justify-between gap-4 mb-2">
          <h2 class="text-lg font-medium">{project.title}</h2>
          <span
            class="text-xs px-2 py-0.5 rounded-full shrink-0"
            style="background-color: var(--bg-secondary); color: var(--text-secondary);"
          >
            {project.status}
          </span>
        </div>
        <p class="text-sm leading-relaxed mb-3" style="color: var(--text-secondary);">
          {project.description}
        </p>
        <div class="flex flex-wrap items-center gap-3 mb-3">
          {project.tags.map((tag) => (
            <span
              class="text-xs px-2 py-0.5 rounded-full"
              style="background-color: var(--bg-secondary); color: var(--text-secondary);"
            >
              {tag}
            </span>
          ))}
        </div>
        <div class="flex gap-4 text-sm">
          {project.page && (
            <a
              href={project.page}
              class="underline underline-offset-2 hover:opacity-70 transition-opacity"
              style="color: var(--accent);"
            >
              View Project &rarr;
            </a>
          )}
          {project.github && (
            <a
              href={project.github}
              target="_blank"
              rel="noopener noreferrer"
              class="underline underline-offset-2 hover:opacity-70 transition-opacity"
              style="color: var(--accent);"
            >
              GitHub &rarr;
            </a>
          )}
          {project.blog && (
            <a
              href={project.blog}
              class="underline underline-offset-2 hover:opacity-70 transition-opacity"
              style="color: var(--accent);"
            >
              Blog Post &rarr;
            </a>
          )}
        </div>
      </div>
    ))}
  </div>
</BaseLayout>
